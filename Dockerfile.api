FROM python:3.12-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY lms_lite_api.py .
COPY lms_lite_v2_routes.py .
COPY lms_lite_cert_utils.py .
COPY lms_lite_tutor.py .
COPY lms_lite_db.json .
COPY templates/ /app/templates/
COPY arquivos_do_projeto/logos/LOGOS_PNG/TDS.PNG.png /app/arquivos_do_projeto/logos/LOGOS_PNG/TDS.PNG.png
COPY courses/ /app/courses/
EXPOSE 8081
CMD ["uvicorn", "lms_lite_api:app", "--host", "0.0.0.0", "--port", "8081"]
