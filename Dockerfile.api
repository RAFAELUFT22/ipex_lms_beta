FROM python:3.12-slim
WORKDIR /app
COPY requirements.txt .
RUN pip install --no-cache-dir -r requirements.txt
COPY lms_lite_api.py .
COPY lms_lite_v2_routes.py .
COPY lms_lite_core.py .
COPY templates/ /app/templates/
COPY lms_lite_db.json* ./
COPY courses/ /app/courses/
EXPOSE 8081
CMD ["uvicorn", "lms_lite_api:app", "--host", "0.0.0.0", "--port", "8081"]
