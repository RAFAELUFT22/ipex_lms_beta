# =============================================================================
# kreativ-education — Environment Variables Template
# Copie para .env e preencha com seus valores reais.
# JAMAIS commite o arquivo .env com senhas reais.
# =============================================================================

# --- MariaDB ---
MARIADB_ROOT_PASSWORD=troque_por_senha_forte_aqui
MARIADB_FRAPPE_PASSWORD=troque_por_senha_frappe_aqui

# --- Frappe Site ---
FRAPPE_SITE_NAME=lms.extensionista.site
FRAPPE_ADMIN_PASSWORD=troque_por_senha_admin_aqui

# --- Frappe API (geradas após setup via scripts/setup.sh) ---
FRAPPE_API_KEY=
FRAPPE_API_SECRET=

# --- URLs Internas (Docker network) ---
FRAPPE_INTERNAL_URL=http://kreativ_frappe_backend:8000
FRAPPE_LMS_URL=https://lms.extensionista.site

# --- Evolution API (WhatsApp) ---
EVOLUTION_API_URL=http://kreativ_evolution:8080
EVOLUTION_INSTANCE=europs

# --- N8N ---
N8N_URL=http://kreativ_n8n:5678
N8N_API_KEY=

# --- PostgreSQL (apenas pgvector/RAG bridge) ---
PG_HOST=kreativ_postgres
PG_PORT=5432
PG_USER=kreativ_user
PG_PASSWORD=troque_por_senha_pg_aqui
PG_DATABASE=kreativ_edu

# --- Traefik / TLS ---
LETSENCRYPT_EMAIL=admin@extensionista.site
DOMAIN=extensionista.site
