# =============================================================================
# TDS (Território de Desenvolvimento Social) — 5-Pillar Environment Variables
# Stack: Evolution, n8n, AnythingLLM, Frappe, Chatwoot
# =============================================================================

# --- Domains ---
DOMAIN=ipexdesenvolvimento.cloud
LETSENCRYPT_EMAIL=admin@ipexdesenvolvimento.cloud

# --- Shared Infrastructure ---
PG_USER=kreativ
PG_PASSWORD=strong_postgres_password
PG_DATABASE=kreativ_edu
MARIADB_ROOT_PASSWORD=mariadb_root_password
MARIADB_FRAPPE_PASSWORD=mariadb_frappe_password
REDIS_PASSWORD=redis_password

# --- Pilar 1: Gateway (Evolution API) ---
EVOLUTION_API_KEY=evolution_api_key_here
EVOLUTION_URL=https://evolution.ipexdesenvolvimento.cloud
EVOLUTION_DB=evolution_db

# --- Pilar 2: Orquestrador (n8n) ---
N8N_ENCRYPTION_KEY=n8n_encryption_key_here
N8N_URL=https://n8n.ipexdesenvolvimento.cloud

# --- Pilar 3: Tutor Cognitivo (AnythingLLM) ---
ANYTHINGLLM_API_KEY=anythingllm_api_key_here
RAG_URL=https://rag.ipexdesenvolvimento.cloud
# LLM Providers (Gemini / Groq / OpenRouter)
GEMINI_API_KEY=
GROQ_API_KEY=
OPENROUTER_API_KEY=

# --- Pilar 4: Fonte da Verdade (Frappe Education) ---
FRAPPE_SITE_NAME=lms.ipexdesenvolvimento.cloud
FRAPPE_API_KEY=
FRAPPE_API_SECRET=

# --- Pilar 5: Inbox Humana (Chatwoot) ---
CHATWOOT_SECRET_KEY=chatwoot_secret_key_here
CHATWOOT_URL=https://chat.ipexdesenvolvimento.cloud
CHATWOOT_API_KEY=

# --- Integration Evolution <-> Chatwoot ---
EVOLUTION_GLOBAL_WEBHOOK=https://n8n.ipexdesenvolvimento.cloud/webhook/whatsapp-kreativ

# --- Pillar 6: Notifications (Mail Relay) ---
SMTP_SERVER=smtp.gmail.com
SMTP_PORT=587
SMTP_USERNAME=
SMTP_PASSWORD=
